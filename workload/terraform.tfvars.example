###############################################################################
# terraform.tfvars.example — Workload
# ----------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in your values.
# The real terraform.tfvars is in .gitignore — never commit it.
#
# REQUIRED: subscription_id and dns_zone_id (no defaults for these).
# OPTIONAL: Everything else has sensible defaults in variables.tf.
#
# To get your dns_zone_id, run:
#   cd ../bootstrap && terraform output dns_zone_id
###############################################################################

# ─── REQUIRED ───────────────────────────────────────────────────────────────

subscription_id = "ec289c8e-4873-4660-a368-35309d8ca713"

dns_zone_id = "/subscriptions/ec289c8e-4873-4660-a368-35309d8ca713/resourceGroups/rg-dns-shared/providers/Microsoft.Network/dnszones/mokcloud.site"

# ─── OPTIONAL (uncomment to override defaults) ─────────────────────────────

# tenant_id               = "6d1a1189-71c0-454f-bd1d-208980e7c2d5"
# dns_zone_name           = "mokcloud.site"
# dns_resource_group_name = "rg-dns-shared"
# primary_location        = "canadacentral"
# secondary_location      = "eastus"
# resource_group_name     = "rg-staticsite-prod"
# project_short_name      = "mksite"
# budget_amount           = 50
# alert_email             = "mokenyukezongwe@outlook.com"
